{
  "name": "project-root",
  "version": "0.0.1",
  "config": {
    "iac": "cdk"
  },
  "scripts": {
    "build": "python3 build.py",
    "build.logic": "python3 build.py --business_logic",
    "build.infrastructure": "python3 build.py --infrastructure",
    "cdk:deploy.bootstrap": "cd infrastructure/aws-cdk && npm install && npm run bootstrap",
    "cdk:deploy": "cd infrastructure/aws-cdk && npm run cdk deploy -- -c stack_name=\"${STACK_NAME:-}\" --all --require-approval never",
    "cdk:destroy": "node scripts/pre-destroy.js; cd infrastructure/aws-cdk && npm run cdk destroy -- -c stack_name=\"${STACK_NAME:-}\" --all",
    "tf:deploy.bootstrap": "cd infrastructure/terraform/src && terraform init && terraform validate && terraform plan",
    "tf:deploy": "cd infrastructure/terraform/src && terraform apply -auto-approve",
    "tf:destroy": "cd infrastructure/terraform/src && terraform destroy",
    "deploy.bootstrap": "npm run $npm_package_config_iac:deploy.bootstrap",
    "deploy": "node validator.js && npm run $npm_package_config_iac:deploy",
    "destroy": "npm run $npm_package_config_iac:destroy",
    "validate": "node validator.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "caniuse-lite": "^1.0.30001646",
    "esbuild": "^0.24.2",
    "js-yaml": "^4.1.0",
    "prettier": "^3.8.3"
  },
  "workspaces": [
    "infrastructure/aws-cdk",
    "business-logic/api/admin",
    "business-logic/api/lambda-authorizer",
    "business-logic/events-processing"
  ],
  "dependencies": {
    "@types/node": "^22.13.17"
  }
}
