          "SqlQuery": "SELECT\\n  events.payload.event.event_id::VARCHAR as event_id,\\n  events.payload.event.event_type::VARCHAR as event_type,\\n  events.payload.event.event_name::VARCHAR as event_name,\\n  events.payload.event.app_version::VARCHAR as app_version,\\n  events.payload.application_id::VARCHAR as application_id,\\n  date(timestamp 'epoch' + events.payload.event.event_timestamp::BIGINT * interval '1 second') as event_date,\\n  date_trunc('hour', timestamp 'epoch' + events.payload.event.event_timestamp::BIGINT * interval '1 second') as event_hour,\\n  NULLIF(events.payload.event.event_data.platform::VARCHAR, '') as platform,\\n  CASE NULLIF(events.payload.event.event_data.country_id::VARCHAR, '')\\n    WHEN 'UK' THEN 'United Kingdom'\\n    ELSE INITCAP(LOWER(NULLIF(events.payload.event.event_data.country_id::VARCHAR, '')))\\n  END as country,\\n  1 as event_count\\nFROM \\"game_events\\".\\"public\\".\\"event_data\\" events"
