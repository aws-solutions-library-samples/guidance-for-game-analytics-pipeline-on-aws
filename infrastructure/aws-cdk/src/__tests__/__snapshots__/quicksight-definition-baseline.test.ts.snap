          },
          "Name": "economy_events",
          "SqlQuery": "SELECT\\n  events.payload.event.event_id::VARCHAR as event_id,\\n  events.payload.event.event_type::VARCHAR as event_type,\\n  date(timestamp 'epoch' + events.payload.event.event_timestamp::BIGINT * interval '1 second') as event_date,\\n  NULLIF(events.payload.event.event_data.item_id::VARCHAR, '') as item_id,\\n  CAST(NULLIF(events.payload.event.event_data.currency_amount::VARCHAR, '') AS INTEGER) as currency_amount,\\n  CASE\\n    WHEN CAST(NULLIF(events.payload.event.event_data.currency_amount::VARCHAR, '') AS INTEGER) BETWEEN 1 AND 9 THEN '01: $1-9'\\n    WHEN CAST(NULLIF(events.payload.event.event_data.currency_amount::VARCHAR, '') AS INTEGER) BETWEEN 10 AND 19 THEN '02: $10-19'\\n    WHEN CAST(NULLIF(events.payload.event.event_data.currency_amount::VARCHAR, '') AS INTEGER) BETWEEN 20 AND 49 THEN '03: $20-49'\\n    WHEN CAST(NULLIF(events.payload.event.event_data.currency_amount::VARCHAR, '') AS INTEGER) BETWEEN 50 AND 99 THEN '04: $50-99'\\n    WHEN CAST(NULLIF(events.payload.event.event_data.currency_amount::VARCHAR, '') AS INTEGER) >= 100 THEN '05: $100+'\\n    ELSE '99: Unknown'\\n  END as currency_amount_band,\\n  NULLIF(events.payload.event.event_data.currency_type::VARCHAR, '') as currency_type,\\n  NULLIF(events.payload.event.event_data.transaction_id::VARCHAR, '') as transaction_id,\\n  NULLIF(events.payload.event.event_data.item_rarity::VARCHAR, '') as item_rarity,\\n  CAST(NULLIF(events.payload.event.event_data.lootbox_cost::VARCHAR, '') AS INTEGER) as lootbox_cost,\\n  1 as event_count\\nFROM \\"game_events\\".\\"public\\".\\"event_data\\" events\\nWHERE events.payload.event.event_type::VARCHAR IN ('iap_transaction', 'lootbox_opened', 'item_viewed')\\n  AND timestamp 'epoch' + events.payload.event.event_timestamp::BIGINT * interval '1 second' >= dateadd(day, -30, getdate())"
